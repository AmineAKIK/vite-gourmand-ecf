# ============================================
# VITE & GOURMAND — Variables d'environnement
# Copier vers .env et remplir les valeurs
# NE JAMAIS COMMITER .env
# ============================================

# Base de données MySQL
DB_HOST=localhost
DB_NAME=vite_gourmand
DB_USER=root
DB_PASS=

# Stripe (paiements CB en ligne — https://dashboard.stripe.com/apikeys)
# sk_test_... en dev, sk_live_... en prod
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret depuis le Stripe Dashboard → Webhooks → votre endpoint /stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Mail SMTP (ex: Mailtrap en dev, Brevo/SES en prod)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=votre_user_mailtrap
MAIL_PASS=votre_pass_mailtrap
MAIL_FROM=noreply@vitegourmand.fr
MAIL_FROM_NAME=Vite & Gourmand

# Application
BASE_URL=http://localhost:8080
APP_ENV=development
# APP_ENV=production  ← valeur à utiliser sur Railway

# Cloudinary (uploads persistants — https://cloudinary.com)
# Requis en production (Railway filesystem éphémère)
# Sans ces variables, les uploads sont stockés dans public/uploads/ (local uniquement)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AkikSystems SaaS Dashboard (admin-saas/)
# Token secret pour protéger le dashboard de provisioning
# Générer avec : php -r "echo bin2hex(random_bytes(32));"
SAAS_SECRET=
