# ============================================
# VITE & GOURMAND — Variables d'environnement
# Copier vers .env et remplir les valeurs
# NE JAMAIS COMMITER .env
# ============================================

# Base de données MySQL
DB_HOST=localhost
DB_NAME=vite_gourmand
DB_USER=root
DB_PASS=

# MongoDB Atlas (statistiques)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGO_DB=vite_gourmand_stats

# Mail SMTP (ex: Mailtrap en dev, Brevo/SES en prod)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=votre_user_mailtrap
MAIL_PASS=votre_pass_mailtrap
MAIL_FROM=noreply@vitegourmand.fr

# Application
BASE_URL=http://localhost:8080
APP_ENV=development
# APP_ENV=production  ← valeur à utiliser sur Railway

# Cloudinary (uploads persistants — https://cloudinary.com)
# Requis en production (Railway filesystem éphémère)
# Sans ces variables, les uploads sont stockés dans public/uploads/ (local uniquement)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
